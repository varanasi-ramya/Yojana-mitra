{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/index.html"
    }
  ],
  "env": {
    "GOOGLE_API_KEY": "@google_api_key",
    "VECTOR_STORE": "@vector_store",
    "FRONTEND_URL": "@frontend_url"
  }
}